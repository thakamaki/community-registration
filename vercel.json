{
  "rewrites": [
    { "source": "/api/pulsara/:path*", "destination": "/api/pulsara" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}


