{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/pulsara.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/pulsara/:path*",
      "destination": "/api/pulsara"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=utf-8" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
